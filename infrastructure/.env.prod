# ElephantBroker — Production Environment Template
# Copy to .env.prod and fill in real values. NEVER commit .env.prod to git.
#
# Usage:
#   cp infrastructure/.env.prod.example infrastructure/.env.prod
#   docker compose -f infrastructure/docker-compose.prod.yml --env-file infrastructure/.env.prod up -d

# ── ElephantBroker identity ────────────────────────────────────────────────────
EB_GATEWAY_ID=gw-prod
EB_ORG_ID=your-org-id
EB_TEAM_ID=your-team-id

# ── LLM (via LiteLLM proxy or OpenAI-compatible endpoint) ─────────────────────
EB_LLM_MODEL=openai/gemini/gemini-2.5-pro
EB_LLM_ENDPOINT=http://your-litellm-proxy:8811/v1
EB_LLM_API_KEY=your-llm-api-key

# ── Embeddings (can be same endpoint as LLM) ──────────────────────────────────
EB_EMBEDDING_ENDPOINT=http://your-litellm-proxy:8811/v1
EB_EMBEDDING_API_KEY=your-embedding-api-key

# ── Reranker (Qwen3-Reranker-4B endpoint — set to your GPU host) ──────────────
EB_RERANKER_ENDPOINT=http://your-reranker-host:1235

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
EB_HITL_CALLBACK_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_32

# ── Infrastructure credentials ────────────────────────────────────────────────
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
NEO4J_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Observability (optional) ──────────────────────────────────────────────────
# Uncomment and set if using the observability profile
# EB_OTEL_ENDPOINT=http://otel-collector:4317
# CLICKHOUSE_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
